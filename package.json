{
  "name": "shipway",
  "version": "0.5.1",
  "description": "Deploy Node.js, Python, and Ruby apps over SSH. Seven lines of YAML. No Docker.",
  "type": "module",
  "bin": {
    "shipway": "./bin/cli.js"
  },
  "files": [
    "bin",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "keywords": [
    "deploy",
    "ssh",
    "rsync",
    "pm2",
    "systemd",
    "mcp",
    "cli",
    "devops"
  ],
  "author": "bernatch22",
  "license": "MIT",
  "homepage": "https://github.com/bernatch22/shipway#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bernatch22/shipway.git"
  },
  "bugs": {
    "url": "https://github.com/bernatch22/shipway/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yaml": "^2.7.1",
    "zod": "^3.25.23"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.1"
  }
}
